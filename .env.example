# =============================================================================
# TradeOff environment variables
# Copy to .env.local for `npm run dev`. Values committed here are placeholders.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser by Next.js.
# Everything else is read by the Cloud Run service in /server and must NEVER
# be referenced from frontend code (architecture rule: keys stay server-side).
# =============================================================================


# -----------------------------------------------------------------------------
# Demo locale
# DEMO_STATE and DEMO_CONSTITUENCY pin the geography the demo is authored
# against. They drive (a) content authoring — the four candidate manifestos
# in /content/candidates are calibrated to the real economic and social
# conditions of DEMO_STATE — and (b) the voter journey page, which uses
# DEMO_CONSTITUENCY to anchor the booth lookup and timeline copy.
# Change these and the manifestos must be re-authored to match.
# -----------------------------------------------------------------------------

DEMO_STATE="West Bengal"
DEMO_CONSTITUENCY="Bhabanipur"


# -----------------------------------------------------------------------------
# Frontend → backend wiring
# -----------------------------------------------------------------------------

# Public URL of the Cloud Run service. In dev, set to http://localhost:8080.
# In production, set to the Cloud Run service URL. The Next.js rewrite in
# next.config.mjs proxies /api/* through this URL.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080


# -----------------------------------------------------------------------------
# Firebase (web client config — exposed to browser, this is expected)
# Get these from Firebase Console → Project settings → General → Your apps.
# Auth uses anonymous sign-in; no user identifiers are required.
# -----------------------------------------------------------------------------

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=


# -----------------------------------------------------------------------------
# Firebase Admin (server-side, /server only)
# FIREBASE_SERVICE_ACCOUNT_JSON: stringified JSON of a service-account key,
# OR leave empty and rely on Application Default Credentials on Cloud Run.
# -----------------------------------------------------------------------------

FIREBASE_PROJECT_ID=your-project
FIREBASE_SERVICE_ACCOUNT_JSON=


# -----------------------------------------------------------------------------
# Google Cloud / Vertex AI
# Vertex AI Search hosts the manifesto retrieval index. Gemini 2.5 Flash is
# called via Vertex AI; an explicit GEMINI_API_KEY is only needed if you call
# the Gemini API directly outside Vertex (not the default).
# -----------------------------------------------------------------------------

GCP_PROJECT_ID=your-project
GCP_LOCATION=us-central1

# Vertex AI Search (manifesto retrieval index)
VERTEX_SEARCH_ENGINE_ID=
VERTEX_SEARCH_LOCATION=global
VERTEX_DATA_STORE_ID=

# Gemini model selection. 2.5 Flash is the documented default per AGENTS.md.
GEMINI_MODEL=gemini-2.5-flash
# Only set if calling Gemini API directly (not via Vertex). Optional.
GEMINI_API_KEY=


# -----------------------------------------------------------------------------
# Google Maps Platform
# Used by /api/booth for pincode-to-booth lookup. Server-side only; the key
# is never exposed to the browser. Restrict the key to Geocoding + Places
# APIs in the GCP console.
# -----------------------------------------------------------------------------

MAPS_API_KEY=


# -----------------------------------------------------------------------------
# Server runtime
# -----------------------------------------------------------------------------

# Port the Cloud Run service listens on. Cloud Run sets this automatically;
# locally, defaults to 8080.
PORT=8080
NODE_ENV=development

# Comma-separated list of allowed frontend origins for CORS. Used by the
# Express CORS middleware so the browser can call the Cloud Run service
# directly (bypassing the Next.js dev proxy that times out at 30s on live
# Gemini calls). Localhost dev origins are allowed implicitly.
CORS_ALLOWED_ORIGINS=


# -----------------------------------------------------------------------------
# Symmetry CI
# -----------------------------------------------------------------------------

# Used by the symmetry CI runner (lib/symmetry/cli.ts) to override the
# backend URL. Defaults to http://localhost:8080. Set this in the CI
# workflow to point at a different host or port.
BACKEND_URL=http://localhost:8080


# -----------------------------------------------------------------------------
# Seed script
# -----------------------------------------------------------------------------

# GCS bucket name for seeding manifesto files into Vertex AI Search via
# `npm --prefix server run seed`. The script uploads each candidate
# manifesto to gs://${SEED_GCS_BUCKET}/manifestos/<candidateId>.txt, then
# triggers a Discovery Engine import to ingest them.
SEED_GCS_BUCKET=
