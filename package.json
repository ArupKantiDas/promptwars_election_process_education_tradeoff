{
  "name": "tradeoff",
  "version": "0.1.0",
  "private": true,
  "description": "TradeOff — manifesto literacy tool for Indian voters (Anti-Gravity hackathon).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=critical --omit=dev",
    "server:dev": "npm --prefix server run dev",
