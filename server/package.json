{
  "name": "tradeoff-server",
  "version": "0.1.0",
  "private": true,
  "description": "TradeOff Cloud Run backend: extract, classify, score, booth.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env.local --env-file-if-exists=../.env.local --import tsx --watch src/index.ts",
    "start:ci": "node --env-file-if-exists=.env.local --env-file-if-exists=../.env.local --import tsx src/index.ts",
    "build": "tsc",
    "start": "node --env-file-if-exists=.env.local dist/index.js",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=high --omit=dev",
    "seed": "node --env-file=.env.local --import tsx src/scripts/seed.ts",
    "test": "node --import tsx --test src/services/missing.test.ts src/llm/scoring.test.ts src/routes/classify.test.ts src/routes/extract.test.ts"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@googlemaps/google-maps-services-js": "^3.4.0",
    "express": "^4.21.0",
    "firebase-admin": "^12.5.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@google-cloud/discoveryengine": "^2.0.0",
    "@google-cloud/storage": "^7.13.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
